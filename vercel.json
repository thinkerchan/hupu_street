{
  "rewrites": [
    {
      "source": "/passport/(.*)",
      "destination": "/api/passport?path=$1"
    },
    {
      "source": "/hupu/(.*)",
      "destination": "/api/hupu?path=$1"
    },
    {
      "source": "/games-api/(.*)",
      "destination": "/api/games-api?path=$1"
    },
    {
      "source": "/bbs-pc/(.*)",
      "destination": "/api/bbs-pc?path=$1"
    },
    {
      "source": "/hoopchina/(.*)",
      "destination": "/api/hoopchina?path=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
