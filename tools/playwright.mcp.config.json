{
  "browser": {
    "browserName": "chromium",
    "launchOptions": {
      "headless": false
    },
    "contextOptions": {
      "viewport": {
        "width": 1280,
        "height": 720
      }
    }
  },
  "server": {
    "host": "127.0.0.1",
    "port": 8940
  },
  "capabilities": [
    "tabs",
    "tracing"
  ],
  "network": {
    "allowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173"
    ]
  },
  "outputDir": "playwright-mcp-artifacts",
  "imageResponses": "omit"
}
